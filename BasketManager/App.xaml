<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BasketManager"
             x:Class="BasketManager.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryGreen">#1DB954</Color>
            <Color x:Key="BackgroundLight">#FFFFFF</Color>
            <Color x:Key="SurfaceLight">#F5F5F5</Color>
            <Color x:Key="BackgroundDark">#121212</Color>
            <Color x:Key="SurfaceDark">#282828</Color>

            <Style x:Key="TitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=Black, Dark=White}" />
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 10" />
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
                <Setter Property="Padding" Value="15" />
                <Setter Property="StrokeThickness" Value="0" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryGreen}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="HeightRequest" Value="45" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

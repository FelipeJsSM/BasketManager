<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BasketManager"
             x:Class="BasketManager.App">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ══ PALETA PRINCIPAL ══ -->
            <Color x:Key="PrimaryOrange">#FF6B00</Color>
            <Color x:Key="PrimaryOrangeLight">#FFB693</Color>
            <Color x:Key="BackgroundDark">#131313</Color>
            <Color x:Key="SurfaceDark">#1C1B1B</Color>
            <Color x:Key="InputDark">#2A2A2A</Color>
            <Color x:Key="TextPrimary">#FFFFFF</Color>
            <Color x:Key="TextSecondary">#888888</Color>
            <Color x:Key="DangerRed">#FF4D4D</Color>

            <!-- ══ TIPOGRAFÍA ══ -->
            <Style x:Key="TitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="CharacterSpacing" Value="1" />
            </Style>

            <Style x:Key="SubtitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="CharacterSpacing" Value="2" />
            </Style>

            <!-- ══ COMPONENTES ══ -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceDark}" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryOrange}" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="HeightRequest" Value="50" />
            </Style>

            <Style x:Key="GhostButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style x:Key="InputStyle" TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="#444444" />
                <Setter Property="BackgroundColor" Value="{StaticResource InputDark}" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
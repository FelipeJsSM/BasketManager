<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:BasketManager.ViewModels"
             xmlns:models="clr-namespace:BasketManager.Models"
             x:Class="BasketManager.CanchaPage"
             x:DataType="viewmodels:MainViewModel"
             BackgroundColor="{StaticResource BackgroundDark}"
             Title="CANCHA">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20" RowSpacing="20">

        <!-- ══ HEADER ══ -->
        <VerticalStackLayout Grid.Row="0" Spacing="6" Margin="0,10,0,0">
            <Label Text="CONTROL DE PARTIDO"
                   Style="{StaticResource TitleStyle}"
                   TextColor="{StaticResource PrimaryOrange}"
                   HorizontalOptions="Start" />
            <BoxView HeightRequest="3"
                     WidthRequest="50"
                     Color="{StaticResource PrimaryOrange}"
                     HorizontalOptions="Start"
                     CornerRadius="2" />
        </VerticalStackLayout>

        <!-- ══ EQUIPOS ══ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">

                <!-- EQUIPO AZUL -->
                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="#2196F3"
                        BackgroundColor="{StaticResource SurfaceDark}"
                        Padding="18">
                    <VerticalStackLayout Spacing="12">

                        <!-- Título equipo -->
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <BoxView Color="#2196F3"
                                     WidthRequest="4"
                                     HeightRequest="20"
                                     CornerRadius="2"
                                     VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="EQUIPO AZUL"
                                   TextColor="#2196F3"
                                   FontAttributes="Bold"
                                   FontSize="14"
                                   CharacterSpacing="2"
                                   Margin="10,0,0,0"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2"
                                   Text="{Binding EquipoA.Count, StringFormat='{0} jugadores'}"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="12"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Separador -->
                        <BoxView HeightRequest="1"
                                 Color="#2A2A2A" />

                        <!-- Jugadores -->
                        <CollectionView ItemsSource="{Binding EquipoA}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Jugador">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10" Margin="0,5">
                                        <Label Text="•"
                                               TextColor="#2196F3"
                                               FontSize="18"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Nombre}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Botón ganar -->
                        <Button Text="🏆  ¡GANÓ AZUL!"
                                Command="{Binding FinalizarJuegoCommand}"
                                CommandParameter="{x:Boolean True}"
                                IsEnabled="{Binding HayJuegoActivo}"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="48" />

                    </VerticalStackLayout>
                </Border>

                <!-- VS -->
                <Grid ColumnDefinitions="*, Auto, *" VerticalOptions="Center">
                    <BoxView Grid.Column="0"
                             HeightRequest="1"
                             Color="#2A2A2A"
                             VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="VS"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#444444"
                           HorizontalOptions="Center"
                           Margin="16,0" />
                    <BoxView Grid.Column="2"
                             HeightRequest="1"
                             Color="#2A2A2A"
                             VerticalOptions="Center" />
                </Grid>

                <!-- EQUIPO ROJO -->
                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="#F44336"
                        BackgroundColor="{StaticResource SurfaceDark}"
                        Padding="18">
                    <VerticalStackLayout Spacing="12">

                        <!-- Título equipo -->
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <BoxView Color="#F44336"
                                     WidthRequest="4"
                                     HeightRequest="20"
                                     CornerRadius="2"
                                     VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="EQUIPO ROJO"
                                   TextColor="#F44336"
                                   FontAttributes="Bold"
                                   FontSize="14"
                                   CharacterSpacing="2"
                                   Margin="10,0,0,0"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2"
                                   Text="{Binding EquipoB.Count, StringFormat='{0} jugadores'}"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="12"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Separador -->
                        <BoxView HeightRequest="1"
                                 Color="#2A2A2A" />

                        <!-- Jugadores -->
                        <CollectionView ItemsSource="{Binding EquipoB}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Jugador">
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10" Margin="0,5">
                                        <Label Text="•"
                                               TextColor="#F44336"
                                               FontSize="18"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Nombre}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Botón ganar -->
                        <Button Text="🏆  ¡GANÓ ROJO!"
                                Command="{Binding FinalizarJuegoCommand}"
                                CommandParameter="{x:Boolean False}"
                                IsEnabled="{Binding HayJuegoActivo}"
                                BackgroundColor="#F44336"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="48" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══ REINICIAR ══ -->
        <Button Grid.Row="2"
                Text="⚠  REINICIAR CANCHA"
                Command="{Binding ReiniciarCanchaCommand}"
                BackgroundColor="{StaticResource InputDark}"
                TextColor="{StaticResource DangerRed}"
                BorderColor="{StaticResource DangerRed}"
                BorderWidth="1"
                CornerRadius="12"
                HeightRequest="50"
                FontAttributes="Bold" />

    </Grid>
</ContentPage>
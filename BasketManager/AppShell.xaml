<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BasketManager.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BasketManager"
    Title="BasketManager">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <TabBar>
        <Tab Title="Registro" Icon="resource_registro.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>
        <Tab Title="Cancha" Icon="resource_basket.png">
            <ShellContent ContentTemplate="{DataTemplate local:CanchaPage}" />
        </Tab>
    </TabBar>

</Shell>

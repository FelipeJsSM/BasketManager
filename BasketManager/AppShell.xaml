<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BasketManager.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BasketManager"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource BackgroundDark}">

    <Shell.Resources>
        <Style TargetType="TabBar">
            <Setter Property="Shell.TabBarBackgroundColor" Value="#1C1B1B" />
            <Setter Property="Shell.TabBarForegroundColor" Value="#FF6B00" />
            <Setter Property="Shell.TabBarTitleColor" Value="#FF6B00" />
            <Setter Property="Shell.TabBarUnselectedColor" Value="#555555" />
        </Style>
    </Shell.Resources>

    <TabBar>
        <Tab Title="Registro">
            <ShellContent
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>

        <Tab Title="Draft">
            <ShellContent
                ContentTemplate="{DataTemplate local:DraftPage}"
                Route="DraftPage" />
        </Tab>

        <Tab Title="Cancha">
            <ShellContent
                ContentTemplate="{DataTemplate local:CanchaPage}"
                Route="CanchaPage" />
        </Tab>
    </TabBar>

</Shell>
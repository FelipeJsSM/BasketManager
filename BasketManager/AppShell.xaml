<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BasketManager.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BasketManager"
    Title="BasketManager">

    <TabBar>
        <Tab Title="Registro">
            <ShellContent 
                ContentTemplate="{DataTemplate local:MainPage}" 
                Route="MainPage" />
        </Tab>

        <Tab Title="Draft">
            <ShellContent ContentTemplate="{DataTemplate local:DraftPage}" Route="DraftPage" />
        </Tab>

        <Tab Title="Cancha">
            <ShellContent ContentTemplate="{DataTemplate local:CanchaPage}" Route="CanchaPage" />
        </Tab>
    </TabBar>

</Shell>
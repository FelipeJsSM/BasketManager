<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BasketManager.Models"
             xmlns:viewmodels="clr-namespace:BasketManager.ViewModels"
             x:Class="BasketManager.MainPage"
             x:DataType="viewmodels:MainViewModel"
             BackgroundColor="{StaticResource BackgroundDark}"
             Title="REGISTRO">

    <Grid RowDefinitions="Auto, Auto, *, Auto" Padding="20" RowSpacing="20">

        <!-- ══ HEADER ══ -->
        <VerticalStackLayout Grid.Row="0" Spacing="6" Margin="0,10,0,0">
            <Label Text="ANOTAR JUGADOR"
                   Style="{StaticResource TitleStyle}"
                   TextColor="{StaticResource PrimaryOrange}" />
            <BoxView HeightRequest="3"
                     WidthRequest="50"
                     Color="{StaticResource PrimaryOrange}"
                     HorizontalOptions="Start"
                     CornerRadius="2" />
        </VerticalStackLayout>

        <!-- ══ FORMULARIO ══ -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <VerticalStackLayout Spacing="18">

                <!-- Nombre -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="NOMBRE COMPLETO" Style="{StaticResource SubtitleStyle}" />
                    <Entry Text="{Binding NombreNuevo}"
                           Placeholder="Escribe el nombre..."
                           Style="{StaticResource InputStyle}" />
                </VerticalStackLayout>

                <!-- Pago -->
                <Border StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource InputDark}"
                        Padding="15,10">
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="¿PAGÓ LA LIGA?"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontAttributes="Bold"
                                   FontSize="14" />
                            <Label Text="Marca si ya realizó el pago"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="11" />
                        </VerticalStackLayout>
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding HaPagadoNuevo}"
                                  Color="{StaticResource PrimaryOrange}"
                                  VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Botón -->
                <Button Text="+ ANOTAR EN LISTA"
                        Command="{Binding AgregarJugadorCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />

            </VerticalStackLayout>
        </Border>

        <!-- ══ LISTA DE ESPERA ══ -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Spacing="12">

                <!-- Encabezado lista -->
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="LISTA DE ESPERA"
                           Style="{StaticResource SubtitleStyle}"
                           VerticalOptions="Center" />
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource PrimaryOrange}"
                            Padding="10,4">
                        <Label Text="{Binding ListaEspera.Count}"
                               TextColor="White"
                               FontSize="12"
                               FontAttributes="Bold" />
                    </Border>
                </Grid>

                <!-- Items -->
                <CollectionView ItemsSource="{Binding ListaEspera}">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,40">
                            <Label Text="🏀" FontSize="40" HorizontalOptions="Center" />
                            <Label Text="Sin jugadores anotados"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="14"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Jugador">
                            <Border StrokeShape="RoundRectangle 12"
                                    StrokeThickness="0"
                                    BackgroundColor="{StaticResource SurfaceDark}"
                                    Margin="0,4"
                                    Padding="15,12">
                                <Grid ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="12">

                                    <!-- Indicador de estado -->
                                    <BoxView Grid.Column="0"
                                             Color="{Binding StatusColor}"
                                             WidthRequest="4"
                                             HeightRequest="36"
                                             CornerRadius="2"
                                             VerticalOptions="Center" />

                                    <!-- Nombre y estado -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Nombre}"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="15" />
                                        <Label Text="✓ PAGO CONFIRMADO"
                                               FontSize="10"
                                               TextColor="{StaticResource PrimaryOrangeLight}"
                                               FontAttributes="Bold"
                                               IsVisible="{Binding HaPagado}" />
                                    </VerticalStackLayout>

                                    <!-- Botón pago -->
                                    <Button Grid.Column="2"
                                            Text="💵"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=AlternarPagoJugadorCommand}"
                                            CommandParameter="{Binding .}" />

                                    <!-- Botón eliminar -->
                                    <Button Grid.Column="3"
                                            Text="🗑"
                                            Style="{StaticResource GhostButtonStyle}"
                                            TextColor="{StaticResource DangerRed}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=EliminarJugadorCommand}"
                                            CommandParameter="{Binding .}" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══ CERRAR JORNADA ══ -->
        <Border Grid.Row="3"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="1"
                Stroke="{StaticResource DangerRed}"
                BackgroundColor="Transparent"
                Margin="0,0,0,10">
            <Button Text="⚠  CERRAR JORNADA"
                    Command="{Binding LimpiarLigaCompletaCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource DangerRed}"
                    FontAttributes="Bold"
                    HeightRequest="50" />
        </Border>

    </Grid>
</ContentPage>
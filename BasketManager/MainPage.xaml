<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BasketManager.Models"
             xmlns:viewmodels="clr-namespace:BasketManager.ViewModels"
             x:Class="BasketManager.MainPage"
             x:DataType="viewmodels:MainViewModel"
             Title="Basket Manager">

    <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
        <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="20">

            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Anotar Jugador Nuevo" Style="{StaticResource TitleStyle}" />

                    <Entry Text="{Binding NombreNuevo}" Placeholder="Nombre completo" />

                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Label Text="¿Pagó la liga?" VerticalOptions="Center" />
                        <CheckBox IsChecked="{Binding HaPagadoNuevo}" />
                    </HorizontalStackLayout>

                    <Button Text="Anotar en Lista" 
                    Command="{Binding AgregarJugadorCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <CollectionView Grid.Row="1" ItemsSource="{Binding ListaEspera}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Jugador">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Eliminar" 
                                       BackgroundColor="Red"
                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=EliminarJugadorCommand}"
                                       CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border Style="{StaticResource CardStyle}" Margin="0,5">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="{Binding Nombre}" VerticalOptions="Center" FontAttributes="Bold" />
                                    <BoxView Grid.Column="1" 
                                     Color="{Binding StatusColor}" 
                                     WidthRequest="15" HeightRequest="15" 
                                     CornerRadius="7.5" VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </VerticalStackLayout>

</ContentPage>

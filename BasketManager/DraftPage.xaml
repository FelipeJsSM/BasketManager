<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BasketManager.Models"
             xmlns:viewmodels="clr-namespace:BasketManager.ViewModels"
             x:Class="BasketManager.DraftPage"
             x:DataType="viewmodels:MainViewModel"
             BackgroundColor="{StaticResource BackgroundDark}"
             Title="DRAFT">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <Grid RowDefinitions="Auto, Auto, *" Padding="20" RowSpacing="20">

        <!-- ══ HEADER ══ -->
        <VerticalStackLayout Grid.Row="0" Spacing="6" Margin="0,10,0,0">
            <Label Text="SALA DE DRAFT"
                   Style="{StaticResource TitleStyle}"
                   TextColor="{StaticResource PrimaryOrange}" />
            <BoxView HeightRequest="3"
                     WidthRequest="50"
                     Color="{StaticResource PrimaryOrange}"
                     HorizontalOptions="Start"
                     CornerRadius="2" />
        </VerticalStackLayout>

        <!-- ══ ACCIÓN PRINCIPAL ══ -->
        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}">
            <VerticalStackLayout Spacing="14">

                <Label Text="Selecciona los jugadores que entrarán a cancha en el siguiente partido."
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="13" />

                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">

                    <!-- Badge conteo -->
                    <Border StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource InputDark}"
                            Padding="14,0">
                        <Label Text="{Binding ListaDraft.Count, StringFormat='{0} en draft'}"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="13"
                               VerticalOptions="Center" />
                    </Border>

                    <Button Grid.Column="1"
                            Text="⚡  LLAMAR"
                            Command="{Binding PrepararDraftCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HeightRequest="46"
                            Padding="16,0" />

                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- ══ LISTA DRAFT ══ -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding ListaDraft}">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,50">
                    <Label Text="⚡" FontSize="40" HorizontalOptions="Center" />
                    <Label Text="Presiona LLAMAR para traer jugadores"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Jugador">
                    <Border StrokeShape="RoundRectangle 14"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource SurfaceDark}"
                            Margin="0,5"
                            Padding="16,14">
                        <Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="10">

                            <!-- Nombre -->
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Nombre}"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="15" />
                                <Label Text="SIN EQUIPO"
                                       FontSize="10"
                                       TextColor="{StaticResource TextSecondary}"
                                       CharacterSpacing="1" />
                            </VerticalStackLayout>

                            <!-- Botón Equipo A -->
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    BackgroundColor="#1A3A5C">
                                <Button Text="A"
                                        BackgroundColor="Transparent"
                                        TextColor="#2196F3"
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Padding="0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=MoverAEquipoACommand}"
                                        CommandParameter="{Binding .}" />
                            </Border>

                            <!-- Botón Equipo B -->
                            <Border Grid.Column="2"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    BackgroundColor="#3A1A1A">
                                <Button Text="B"
                                        BackgroundColor="Transparent"
                                        TextColor="#F44336"
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Padding="0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=MoverAEquipoBCommand}"
                                        CommandParameter="{Binding .}" />
                            </Border>

                            <!-- Botón Saltar -->
                            <Border Grid.Column="3"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    BackgroundColor="{StaticResource InputDark}">
                                <Button Text="⏭"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource TextSecondary}"
                                        FontSize="14"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Padding="0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=SaltarJugadorDraftCommand}"
                                        CommandParameter="{Binding .}" />
                            </Border>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>